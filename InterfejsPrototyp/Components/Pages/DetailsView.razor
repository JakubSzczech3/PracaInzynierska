@page "/profile/view/{Tab}"
@rendermode InteractiveServer
@inject ProjectDbContext DB
@inject SharedStateService SharedState
@inject NavigationManager Navigation
@inject ProtectedSessionStorage SessionStorage
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using Microsoft.EntityFrameworkCore
@using InterfejsPrototyp.Other
@using System.ComponentModel.DataAnnotations.Schema

<PageTitle>@GetTitle()</PageTitle>

<header class="header-section">
    <div class="header-left">
        <div class="header-logo" @onclick='() => Navigation.NavigateTo("/profile")'></div>
        <h1>@GetTitle()</h1>
    </div>
</header>

<main class="main-content-area">
    @if (isChecking)
    {
        <div class="loader-container">
            <p>Checking...</p>
        </div>
    }
    else if (SharedState.UserId <= 0)
    {
        <div class="access-denied-container">
            <div class="access-card">
                <h2>Access denied</h2>
                <p>You must be logged in to access your profile and settings.</p>
                <div class="access-actions">
                    <button class="btn-login" @onclick="GoToLogin">Sign in</button>
                    <button class="btn-home" @onclick="GoToHome">Back to home</button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="detail-container">
            <div class="content-card">
                @if (Tab == "purchase-history")
                {
                    @if (!purchaseHistory.Any())
                    {
                        <p class="empty-msg">No orders found.</p>
                    }
                    else
                    {
                        <div class="products-flex-container">
                            @foreach (var order in purchaseHistory)
                            {
                                <div class="product-horizontal-card">
                                    <div class="product-main-info">
                                        <img src="@(string.IsNullOrEmpty(order.Product?.ImageUrl) ? "/images/default-product.png" : order.Product.ImageUrl)"
                                             alt="product thumb" class="product-mini-img" />

                                        <div class="product-text-details">
                                            <span class="product-name">@order.Product?.Name</span>
                                            <div class="product-meta">
                                                <span class="price">@order.TotalAmount.ToString("N2") PLN</span>
                                                <span class="item-date">Purchased: @order.OrderDate.ToString("dd.MM.yyyy")</span>
                                            </div>
                                            <div class="order-details-small">
                                                <span>Quantity: @order.Quantity pcs</span>
                                                <span class="status-badge @order.Status.ToLower()">@order.Status</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
                else if (Tab == "my-products")
                {
                    <div class="list-view">
                        <h3 class="section-title">Selling:</h3>
                        @if (!userProducts.Any())
                        {
                            <p class="empty-msg">You have no active listings.</p>
                        }
                        else
                        {
                            <div class="products-flex-container">
                                @foreach (var prod in userProducts)
                                {
                                    <div class="product-horizontal-card">
                                        <div class="product-main-info">
                                            <img src="@(string.IsNullOrEmpty(prod.ImageUrl) ? "/images/default-product.png" : prod.ImageUrl)"
                                                 alt="product thumb" class="product-mini-img" />

                                            <div class="product-text-details">
                                                <span class="product-name">@prod.Name</span>
                                                <div class="product-meta">
                                                    <span class="price">@prod.Price.ToString("N2") PLN</span>
                                                    <span class="stock">Stock: @prod.StockQuantity</span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="product-actions">
                                            <button class="btn-edit-custom" @onclick='() => Navigation.NavigateTo($"/edit-product/{prod.ProductId}")'>
                                                Edit
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else if (Tab == "my-reviews")
                {
                    <div class="list-view">
                        <h3 class="section-title">Your reviews:</h3>
                        @if (!userReviews.Any())
                        {
                            <p class="empty-msg">You haven't written any reviews yet.</p>
                        }
                        else
                        {
                            <div class="products-flex-container">
                                @foreach (var rev in userReviews)
                                {
                                    <div class="product-horizontal-card">
                                        <div class="product-main-info">
                                            <div class="product-text-details">
                                                <span class="product-name">Product: @rev.Product.Name</span>
                                                <span class="product-name">Rating: @rev.Rating/5</span>
                                                <p class="review-comment">"@rev.Comment"</p>
                                                <small class="item-date">@rev.CreatedAt.ToString("dd.MM.yyyy")</small>
                                            </div>
                                        </div>
                                        <div class="product-actions">
                                            <button class="btn-edit-custom" @onclick="() => DeleteReview(rev.ReviewId)">
                                                Delete
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else if (Tab == "sold-products")
                {
                    <div class="list-view">
                        <h3 class="section-title">Sold items & Shipping details</h3>

                        @if (ordersForMyProducts == null || !ordersForMyProducts.Any())
                        {
                            <p class="empty-msg">No products have been sold yet.</p>
                        }
                        else
                        {
                            <div class="products-flex-container">
                                @foreach (var item in ordersForMyProducts)
                                {
                                    <div class="product-horizontal-card sold-item-border" style="flex-direction: column; align-items: flex-start;">
                                        <div style="display: flex; justify-content: space-between; width: 100%; align-items: center;">
                                            <div class="product-main-info">
                                                <img src="@(string.IsNullOrEmpty(item.Order.Product.ImageUrl) ? "/images/default-product.png" : item.Order.Product.ImageUrl)"
                                                     class="product-mini-img grayscale" alt="Sold product image" />
                                                <div class="product-text-details">
                                                    <span class="product-name">@item.Order.Product.Name</span>
                                                    <span class="price-sold">Paid: @item.Order.TotalAmount.ToString("N2") PLN</span>
                                                    <span class="quantity">Quantity: @item.Order.Quantity pcs</span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="shipping-info-box">
                                            <strong><i class="bi bi-geo-alt"></i> Shipping address:</strong>
                                            @if (item.CustomerAddress != null)
                                            {
                                                <div class="customer-data">
                                                    <span>@item.Customer?.FirstName @item.Customer?.LastName</span>
                                                    <span>Tel: @item.Customer?.PhoneNumber</span>
                                                </div>
                                                <div class="address-data">
                                                    <span>@item.CustomerAddress.StreetAddress</span>
                                                    <span>@item.CustomerAddress.PostalCode @item.CustomerAddress.City</span>
                                                    <span>@item.CustomerAddress.CountryName</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="customer-data">
                                                    <span>@item.Customer?.FirstName @item.Customer?.LastName</span>
                                                </div>
                                                <span class="empty-msg">Shipping address not found in database.</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</main>


<footer class="footer-section">
    Footer
</footer>

@code {
    [Parameter] public string Tab { get; set; } = "";
    private bool isChecking = true;
    private int loggedUserId;
    private void GoToLogin() => Navigation.NavigateTo("/login");
    private void GoToHome() => Navigation.NavigateTo("/", forceLoad: true);
    private List<Product> userProducts = new(); 
    private List<Product> soldProducts = new(); 
    private List<Order> purchaseHistory = new(); 
    private List<Review> userReviews = new();



    protected override Task OnParametersSetAsync()
    {
        return Task.CompletedTask;
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var result = await SessionStorage.GetAsync<int>("userId");

                if (result.Success && result.Value > 0)
                {
                    var resultName = await SessionStorage.GetAsync<string>("userName");
                    SharedState.Login(result.Value, resultName.Value ?? "User");
                    await LoadTabData();
                }
                isChecking = false;
                StateHasChanged();
            }
            catch
            {
                isChecking = false;
                StateHasChanged();
            }
        }
    }
    public class SoldOrderDTO
    {
        public Order Order { get; set; }
        public Customer Customer { get; set; }
        public Address CustomerAddress { get; set; }
    }
    private List<SoldOrderDTO> ordersForMyProducts = new();
    private async Task LoadTabData()
    {
        if (SharedState.UserId <= 0) return;

        if (Tab == "my-products")
        {
            var soldProductIds = await DB.Orders.Select(o => o.ProductId).ToListAsync();
            userProducts = await DB.Products
                .Where(p => p.SellerId == SharedState.UserId && !soldProductIds.Contains(p.ProductId))
                .ToListAsync();
        }
        else if (Tab == "sold-products")
        {
            var rawOrders = await DB.Orders
                .Include(o => o.Product) 
                .Select(o => new SoldOrderDTO
                {
                    Order = o,
                    Customer = DB.Customers.FirstOrDefault(c => c.CustomerId == o.CustomerId),
                    CustomerAddress = DB.Addresses.FirstOrDefault(a => a.CustomerId == o.CustomerId)
                })
                .ToListAsync();


            ordersForMyProducts = rawOrders
                .OrderByDescending(o => o.Order.OrderDate)
                .ToList();
        }
        else if (Tab == "purchase-history")
        {
            purchaseHistory = await DB.Orders
                .Include(o => o.Product)
                .Where(o => o.CustomerId == SharedState.UserId)
                .OrderByDescending(o => o.OrderDate)
                .ToListAsync();
        }
        else if (Tab == "my-reviews")
        {
            userReviews = await DB.Reviews
                .Include(r => r.Product)
                .Where(r => r.CustomerId == SharedState.UserId)
                .ToListAsync();
        }

        StateHasChanged();
    }

    private async Task DeleteReview(int reviewId)
    {
        var review = await DB.Reviews.FindAsync(reviewId);
        if (review != null)
        {
            DB.Reviews.Remove(review);
            await DB.SaveChangesAsync();
            await LoadTabData(); 
        }
    }
    private string GetTitle() => Tab switch
    {
        "my-products" => $"{SharedState.UserName}'s products",
        "sold-products" => $"{SharedState.UserName}'s sold items",
        "purchase-history" => $"{SharedState.UserName}'s order history",
        "my-reviews" => $"{SharedState.UserName}'s reviews",
        _ => "Settings"
    };
}