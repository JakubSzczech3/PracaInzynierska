@page "/product/{Id:int}"
@rendermode InteractiveServer
@using InterfejsPrototyp.Other
@using Microsoft.EntityFrameworkCore
@inject ProjectDbContext DB
@inject NavigationManager Navigation
@inject SharedStateService SharedState
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedSessionStorage SessionStorage

<header class="header-section">
    <div class="header-left">
        <div class="header-logo" @onclick="GoToHome"></div>
        <button class="return-button" @onclick="GoToProduct">&laquo; Back to products</button>
    </div>
    <div class="header-right">
        @if (SharedState.IsLoggedIn)
        {
            <div class="user-dropdown-container">
                <div class="dropdown-trigger" @onclick="ToggleDropdown">
                    Witaj, <b>@SharedState.UserName</b>! <span class="arrow">▼</span>
                </div>
                @if (isDropdownOpen)
                {
                    <div class="dropdown-menu">
                        <button class="dropdown-item" @onclick="GoToProfile">Profile</button>
                        <hr class="dropdown-divider" />
                        <button class="dropdown-item logout" @onclick="HandleLogout">Log out</button>
                    </div>
                }
            </div>
        }
        else
        {
            <button class="auth-button" @onclick="GoToLogin">Log in</button>
        }
    </div>
</header>

<div class="main-wrapper">
    @if (product is null)
    {
        <div class="loader-box">
            <div class="spinner"></div>
            <p>Loading...</p>
        </div>
    }
    else
    {
        <article class="product-container">
            <section class="product-gallery">
                <div class="main-image-box">
                    <img src="@mainImageUrl" class="product-main-img" alt="@product.Name" />
                </div>

                @if (productImages != null && productImages.Count > 1)
                {
                    <div class="thumbnail-list">
                        @foreach (var img in productImages)
                        {
                            <div class="thumb-item @(mainImageUrl == img.ImagePath ? "active-thumb" : "")"
                                 @onclick="() => mainImageUrl = img.ImagePath">
                                <img src="@img.ImagePath" />
                            </div>
                        }
                    </div>
                }
            </section>

            <section class="product-info">
                <nav class="breadcrumb-trail">
                    <span class="category">@categoryName</span>
                    <span class="divider">|</span>
                    <span class="condition">@product.Condition</span>
                </nav>

                <h1 class="product-name">@product.Name</h1>

                @if (reviews.Any())
                {
                    <div class="rating-summary">
                        <span class="stars">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span>@(i <= Math.Round(AverageRating) ? "★" : "☆")</span>
                            }
                        </span>
                        <span class="review-count">(@reviews.Count reviews)</span>
                    </div>
                }

                <div class="price-tag">@product.Price.ToString("N2") PLN</div>

                <div class="purchase-box">
                    @if (product.StockQuantity > 0)
                    {
                        <div class="quantity-selector">
                            <label>Select quantity:</label>
                            <div class="input-row">
                                <input type="number" class="qty-input" @bind="selectedQuantity" min="1" max="@product.StockQuantity" />
                                <span class="stock-status">Available: <b>@product.StockQuantity pcs.</b></span>
                            </div>
                        </div>
                        <button class="buy-button" @onclick="AddToCart">Add to cart</button>
                    }
                    else
                    {
                        <div class="out-of-stock-msg">Product out of stock.</div>
                    }
                </div>

                <div class="description-section">
                    <h3>Description:</h3>
                    <p>@product.Description</p>
                </div>

                <div class="seller-card">
                    <span class="label">Seller:</span>
                    <span class="value">@sellerName</span>
                </div>
            </section>
        </article>

        <section class="reviews-area">
            <h2 class="reviews-title">Customer reviews (@reviews.Count)</h2>

            @if (SharedState.UserId > 0)
            {
                <div class="add-review-form">
                    <h3>Add a review</h3>
                    <div class="form-grid">
                        <div class="field-group">
                            <label>Rating</label>
                            <select @bind="newReview.Rating" class="rating-select">
                                <option value="5">5 - Excellent</option>
                                <option value="4">4 - Good</option>
                                <option value="3">3 - Average</option>
                                <option value="2">2 - Poor</option>
                                <option value="1">1 - Terrible</option>
                            </select>
                        </div>
                        <div class="field-group full-width">
                            <textarea @bind="newReview.Comment" placeholder="What do you think about this product?"></textarea>
                        </div>
                        <div class="form-actions">
                            <button class="submit-review-btn" @onclick="SubmitReview">Post review</button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="login-prompt">
                    Please <a href="/login">login</a> to leave a review.
                </div>
            }

            <div class="reviews-list">
                @if (!reviews.Any())
                {
                    <div class="no-reviews">No reviews yet. Share your opinion!</div>
                }
                else
                {
                    @foreach (var rev in reviews)
                    {
                        <div class="review-card">
                            <div class="review-header">
                                <div class="user-info">
                                    <span class="user-name">@(rev.Customer?.FirstName ?? "User")</span>
                                    <div class="user-rating">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span>@(i <= rev.Rating ? "★" : "☆")</span>
                                        }
                                    </div>
                                </div>

                                @if (currentUserRole == "Admin")
                                {
                                    <div class="admin-actions">
                                        <button class="btn-delete" @onclick="() => DeleteReview(rev.ReviewId)">Delete</button>
                                        <button class="btn-ban" @onclick="() => BanUser(rev.CustomerId)">Ban & Clean</button>
                                    </div>
                                }
                            </div>
                            <p class="review-text">@rev.Comment</p>
                        </div>
                    }
                }
            </div>
        </section>
    }
</div>


<footer class="footer-section">
    Footer
</footer>

@code {
    [Parameter] public int Id { get; set; }
    private Product? product;
    private string sellerName = "";
    private string categoryName = "";
    private int selectedQuantity = 1;
    private string mainImageUrl = "/uploads/placeholder.jpg";
    private List<ProductImage> productImages = new();
    private List<Review> reviews = new();
    private Review newReview = new Review { Rating = 5 };
    private double AverageRating => reviews.Any() ? reviews.Average(r => r.Rating) : 0;
    private string currentUserRole = "";

    protected override async Task OnInitializedAsync()
    {

        product = await DB.Products.AsNoTracking()
            .FirstOrDefaultAsync(p => p.ProductId == Id);

        if (product != null)
        {
            productImages = await DB.ProductImages
            .AsNoTracking()
            .Where(img => img.ProductId == Id)
            .ToListAsync();

            mainImageUrl = productImages.FirstOrDefault()?.ImagePath ?? "/uploads/placeholder.jpg";
            var cat = await DB.Categories.AsNoTracking()
                .FirstOrDefaultAsync(c => c.CategoryId == product.CategoryId);
            categoryName = cat?.Name ?? "Unknown";


            var seller = await DB.Customers.AsNoTracking()
                .FirstOrDefaultAsync(c => c.CustomerId == product.SellerId);
            sellerName = seller?.FirstName ?? "Unknown Seller";

            await LoadReviews();

            if (SharedState.UserId > 0)
            {
                var user = await DB.Customers.AsNoTracking()
                    .FirstOrDefaultAsync(c => c.CustomerId == SharedState.UserId);
                currentUserRole = user?.Role ?? "";
            }
        }
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var resultId = await SessionStorage.GetAsync<int>("userId");
            var resultName = await SessionStorage.GetAsync<string>("userName");

            if (resultId.Success && resultName.Success)
            {
                if (!SharedState.IsLoggedIn)
                {
                    SharedState.Login(resultId.Value, resultName.Value!);
                    var user = await DB.Customers.AsNoTracking()
                    .FirstOrDefaultAsync(c => c.CustomerId == resultId.Value);
                    currentUserRole = user?.Role ?? "";
                    StateHasChanged();
                }
            }
        }
    }
    private async Task LoadReviews()
    {
        reviews = await DB.Reviews
            .Include(r => r.Customer)
            .Where(r => r.ProductId == Id)
            .OrderByDescending(r => r.CreatedAt)
            .ToListAsync();
    }

    private async Task SubmitReview()
    {
        if (SharedState.UserId <= 0) return;
        if (string.IsNullOrWhiteSpace(newReview.Comment)) return;

        newReview.ProductId = Id;
        newReview.CustomerId = SharedState.UserId;
        newReview.CreatedAt = DateTime.Now;

        DB.Reviews.Add(newReview);
        await DB.SaveChangesAsync();

        newReview = new Review { Rating = 5, Comment = "" };
        await LoadReviews();
    }

    private async Task AddToCart()
    {
        if (SharedState.UserId <= 0)
        {
            Navigation.NavigateTo("/login");
            return;
        }


        var dbProduct = await DB.Products.FindAsync(product.ProductId);

        if (dbProduct != null && selectedQuantity > 0)
        {

            if (selectedQuantity > dbProduct.StockQuantity)
            {
                selectedQuantity = dbProduct.StockQuantity;
            }

            var existingItem = await DB.CartItems
                .FirstOrDefaultAsync(c => c.ProductId == product.ProductId && c.CustomerId == SharedState.UserId);

            if (existingItem != null)
            {
                if (existingItem.Quantity + selectedQuantity > dbProduct.StockQuantity)
                {
                    existingItem.Quantity = dbProduct.StockQuantity;
                }
                else
                {
                    existingItem.Quantity += selectedQuantity;
                }
            }
            else
            {
                var newItem = new CartItems
                {
                    CustomerId = SharedState.UserId,
                    ProductId = product.ProductId,
                    Quantity = selectedQuantity,
                    DateAdded = DateTime.Now
                };
                DB.CartItems.Add(newItem);
            }

            await DB.SaveChangesAsync();
            SharedState.NotifyStateChanged();
            Navigation.NavigateTo("/cart");
        }
    }

    private async Task DeleteReview(int reviewId)
    {
        var review = await DB.Reviews.FindAsync(reviewId);
        if (review != null)
        {
            DB.Reviews.Remove(review);
            await DB.SaveChangesAsync();
            await LoadReviews(); 
        }
    }
    private async Task BanUser(int customerId)
    {
        var user = await DB.Customers.FirstOrDefaultAsync(c => c.CustomerId == customerId);
        if (user != null)
        {

            user.IsBanned = true;


            var userReviews = await DB.Reviews.Where(r => r.CustomerId == customerId).ToListAsync();


            DB.Reviews.RemoveRange(userReviews);

            await DB.SaveChangesAsync();
            await LoadReviews(); 
        }
    }



    private void GoToProduct() => Navigation.NavigateTo("/products", forceLoad: true);
    private void GoToHome() => Navigation.NavigateTo("/", forceLoad: true);
    private void GoToProfile() => Navigation.NavigateTo("/profile");
    private void GoToLogin() => Navigation.NavigateTo("/login");
    private async Task HandleLogout()
    {
        isDropdownOpen = false;
        SharedState.Logout();
        try
        {
            await SessionStorage.DeleteAsync("userId");
            await SessionStorage.DeleteAsync("userName");
        }
        catch
        {
        }
    }
    private bool isDropdownOpen = false;

    private void ToggleDropdown()
    {
        isDropdownOpen = !isDropdownOpen;
        StateHasChanged();
    }


}