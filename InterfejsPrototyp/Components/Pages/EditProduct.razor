@page "/edit-product/{ProductId:int}"
@rendermode InteractiveServer
@using InterfejsPrototyp.Other
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using Microsoft.AspNetCore.Components.Forms
@inject ProtectedSessionStorage SessionStorage
@inject SharedStateService SharedState
@inject NavigationManager Navigation
@inject ProjectDbContext DB
@inject IWebHostEnvironment Environment

<PageTitle>Edit Product - @(productToEdit?.Name ?? "Loading")</PageTitle>

<header class="header-section">
    <div class="header-left">
        <div class="header-logo" @onclick="GoToHome"></div>
        <h1>Edit offer</h1>
    </div>
    @if (SharedState.UserId > 0)
    {
        <div class="header-right">
            <span class="welcome-text">Logged in as: <b>@SharedState.UserName</b></span>
            <button class="auth-button ms-3" @onclick="HandleLogout">Log out</button>
        </div>
    }
</header>

<main class="main-content-area">
    <div class="add-product-container">
        @if (loggedUserId > 0)
        {
            <div class="card shadow-lg">
                <div class="card-header">
                    <h3 class="mb-0">Edit your listing #@ProductId</h3>
                </div>
                <div class="card-body">
                    @if (productToEdit == null)
                    {
                        <div class="text-center p-5">
                            <p>Loading offer details...</p>
                        </div>
                    }
                    else
                    {
                        <div class="form-section mb-3">
                            <label>Product name</label>
                            <input @bind="productToEdit.Name" class="form-control" placeholder="Enter product name..." />
                        </div>

                        <div class="form-section mb-3">
                            <label>Description</label>
                            <textarea @bind="productToEdit.Description" class="form-control" rows="3" placeholder="Enter product description..."></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-4 form-section mb-3">
                                <label>Price</label>
                                <input type="number" @bind="productToEdit.Price" class="form-control" step="0.01" />
                            </div>
                            <div class="col-md-4 form-section mb-3">
                                <label>Condition</label>
                                <select @bind="productToEdit.Condition" class="form-control">
                                    <option value="New">New</option>
                                    <option value="Used">Used</option>
                                </select>
                            </div>
                            <div class="col-md-4 form-section mb-3">
                                <label>Stock quantity</label>
                                <input type="number" @bind="productToEdit.StockQuantity" class="form-control" />
                            </div>
                        </div>

                        <div class="form-section mb-4">
                            <div class="form-check form-switch p-3 bg-light rounded border">
                                <input class="form-check-input ms-0" type="checkbox" @bind="productToEdit.IsActive" id="activeSwitch">
                                <label class="form-check-label ms-2" for="activeSwitch">
                                    <strong>Active listing</strong> (Visible to other buyers)
                                </label>
                            </div>
                        </div>

                        <div class="mt-4">
                            <button class="btn btn-primary btn-lg w-100" @onclick="UpdateProduct"
                                    disabled="@(string.IsNullOrEmpty(productToEdit.Name))">
                                Save changes
                            </button>
                            <button class="btn btn-secondary w-100 mt-2" @onclick="GoToMyProducts">
                                Cancel
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
        else if (!isChecking)
        {
            <div class="access-denied-container">
                <div class="access-card">
                    <h2>Access Denied</h2>
                    <p>You must be logged in to manage your items.</p>
                    <div class="access-actions">
                        <button class="btn-login" @onclick="GoToLogin">Log In</button>
                        <button class="btn-home" @onclick="GoToHome">Back to Home</button>
                    </div>
                </div>
            </div>
        }
    </div>
</main>

<footer class="footer-section">
    Footer
</footer>

@code {
    [Parameter] public int ProductId { get; set; }
    private Product? productToEdit;
    private int loggedUserId;
    private bool isChecking = true;

    private void GoToHome() => Navigation.NavigateTo("/", forceLoad: true);
    private void GoToLogin() => Navigation.NavigateTo("/login");
    private void GoToMyProducts() => Navigation.NavigateTo("/profile/view/my-products");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var result = await SessionStorage.GetAsync<int>("userId");
                if (result.Success && result.Value > 0)
                {
                    loggedUserId = result.Value;
                    productToEdit = await DB.Products.FirstOrDefaultAsync(p => p.ProductId == ProductId && p.SellerId == loggedUserId);
                }
            }
            catch { }

            isChecking = false;
            StateHasChanged();
        }
    }

    private async Task UpdateProduct()
    {
        if (productToEdit != null)
        {
            try
            {
                await DB.SaveChangesAsync();
                Navigation.NavigateTo("/profile/view/my-products");
            }
            catch (Exception ex)
            {
                Console.WriteLine("Error: " + ex.Message);
            }
        }
    }

    private async Task HandleLogout()
    {
        SharedState.Logout();
        try
        {
            await SessionStorage.DeleteAsync("userId");
            await SessionStorage.DeleteAsync("userName");
        }
        catch { }
        GoToHome();
    }
}