@page "/delete-account"
@rendermode InteractiveServer
@using InterfejsPrototyp.Other
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using BCrypt.Net;
@inject ProtectedSessionStorage SessionStorage
@inject SharedStateService SharedState
@inject NavigationManager Navigation
@inject ProjectDbContext DB

<PageTitle>Delete Account</PageTitle>

<header class="header-section">
    <div class="header-left">
        <div class="header-logo" @onclick="GoToHome"></div>
        <h1>Settings</h1>
    </div>
</header>

<main class="main-content-area">
    @if (isChecking)
    {
        <div class="loader-box">
            <p>Verifying session...</p>
        </div>
    }
    else if (loggedUserId > 0)
    {
        <section class="delete-account-container">
            <div class="delete-card">
                <div class="delete-card-header">
                    <h3><strong>@SharedState.UserName</strong> delete your account permanently</h3>
                </div>
                <div class="delete-card-body">
                    <div class="warning-banner">
                        <strong>Warning!</strong> This action is irreversible. All your products, history, and address data will be permanently removed from our database.
                    </div>

                    <div class="confirmation-form">
                        <div class="input-group">
                            <label>To confirm deletion, please enter your password:</label>
                            <input type="password" @bind="passwordConfirmation" placeholder="Current password" />
                        </div>

                        <div class="checkbox-group">
                            <input type="checkbox" @bind="isConfirmed" id="confirmCheck" />
                            <label for="confirmCheck">
                                I understand the consequences and want to delete my account.
                            </label>
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <p class="error-text">@errorMessage</p>
                        }

                        <div class="form-actions">
                            <button class="confirm-delete-btn" @onclick="HandleDelete" disabled="@(!isConfirmed)">
                                Confirm permanent deletion
                            </button>
                            <button class="cancel-btn" @onclick="GoToProfile">
                                Cancel and go back
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }
    else
    {
        <div class="access-denied-container">
            <div class="access-card">
                <h2>Access Denied</h2>
                <p>You must be logged in to access security settings.</p>
                <div class="access-actions">
                    <button class="btn-login" @onclick="GoToLogin">Sign In</button>
                    <button class="btn-home" @onclick="GoToHome">Back to Home</button>
                </div>
            </div>
        </div>
    }
</main>

<footer class="footer-section">
    Footer
</footer>

@code {
    private int loggedUserId;
    private bool isChecking = true;
    private string passwordConfirmation = "";
    private bool isConfirmed = false;
    private string errorMessage = "";

    private void GoToHome() => Navigation.NavigateTo("/", forceLoad: true);
    private void GoToProfile() => Navigation.NavigateTo("/profile");
    private void GoToLogin() => Navigation.NavigateTo("/login");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var result = await SessionStorage.GetAsync<int>("userId");
                if (result.Success && result.Value > 0)
                {
                    loggedUserId = result.Value;
                    if (string.IsNullOrEmpty(SharedState.UserName))
                    {
                        var nameResult = await SessionStorage.GetAsync<string>("userName");
                        SharedState.Login(loggedUserId, nameResult.Value ?? "User");
                    }
                }
            }
            catch { }
            isChecking = false;
            StateHasChanged();
        }
    }
    

    private async Task HandleDelete()
    {
        errorMessage = "";
        if (string.IsNullOrWhiteSpace(passwordConfirmation))
        {
            errorMessage = "Password is required.";
            return;
        }

        var customer = await DB.Customers.FirstOrDefaultAsync(c => c.CustomerId == loggedUserId);

        if (customer != null)
        {
            bool isPasswordCorrect = BCrypt.Verify(passwordConfirmation, customer.PasswordHash.Trim());

            if (isPasswordCorrect)
            {
                try
                {
                    var address = await DB.Addresses.FirstOrDefaultAsync(a => a.CustomerId == loggedUserId);
                    if (address != null) DB.Addresses.Remove(address);

                    DB.Customers.Remove(customer);
                    await DB.SaveChangesAsync();

                    SharedState.Logout();
                    await SessionStorage.DeleteAsync("userId");
                    await SessionStorage.DeleteAsync("userName");
                    Navigation.NavigateTo("/", forceLoad: true);
                }
                catch { errorMessage = "Database error during deletion."; }
            }
            else
            {
                errorMessage = "Invalid password.";
            }
        }
    }
}