@page "/cart"
@rendermode InteractiveServer
@using InterfejsPrototyp.Other
@using Microsoft.EntityFrameworkCore
@inject SharedStateService SharedState
@inject NavigationManager Navigation
@inject ProjectDbContext DB

<div class="container mt-5">
    @if (SharedState.UserId <= 0)
    {
        <div class="alert alert-danger shadow-sm">
            <h4><i class="bi bi-lock-fill"></i> Access Denied</h4>
            <p>You must be logged in to view your cart.</p>
            <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/login")'>Login</button>
        </div>
    }
    else
    {
        <div class="cart-header d-flex justify-content-between align-items-center mb-4">
            @if (!string.IsNullOrEmpty(SharedState.UserName))
            {
                <h2><i class="bi bi-cart3"></i> @SharedState.UserName's Shopping Cart</h2>
            }
            else
            {
                <h2><i class="bi bi-cart3"></i> Your Shopping Cart</h2>
            }
            <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/products")'>
                Continue Shopping
            </button>
        </div>

        @if (cartItems == null)
        {
            <div class="text-center mt-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2">Connecting to database...</p>
            </div>
        }
        else if (cartItems.Count == 0)
        {
            <div class="empty-cart-msg text-center p-5 bg-white rounded shadow-sm">
                <i class="bi bi-cart-x display-1 text-muted"></i>
                <h3 class="mt-3">Your cart is empty</h3>
                <p>Browse our products and add them to your cart!</p>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-md-8">
                    @foreach (var item in cartItems)
                    {
                        if (item.Product != null)
                        {
                            <div class="cart-item-row d-flex align-items-center p-3 mb-2 bg-white rounded shadow-sm">
                                <img src="@(string.IsNullOrEmpty(item.Product.ImageUrl) ? "/uploads/placeholder.jpg" : item.Product.ImageUrl)"
                                     class="cart-img-preview" />

                                <div class="ms-3 flex-grow-1">
                                    <h5 class="mb-0">@item.Product.Name</h5>
                                    <small class="text-muted">Price: @item.Product.Price.ToString("N2") PLN</small>
                                </div>

                                <div class="qty-section d-flex align-items-center">
                                    <button class="btn btn-sm btn-outline-dark" @onclick="() => UpdateQty(item, -1)">-</button>
                                    <b class="mx-3">@item.Quantity</b>
                                    <button class="btn btn-sm btn-outline-dark" @onclick="() => UpdateQty(item, 1)">+</button>
                                </div>

                                <div class="ms-4 fw-bold" style="min-width: 100px;">
                                    @((item.Product.Price * item.Quantity).ToString("N2")) PLN
                                </div>

                                <button class="btn btn-link text-danger ms-2" @onclick="() => RemoveItem(item)">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>
                        }
                    }
                </div>

                <div class="col-md-4">
                    <div class="summary-card p-4 bg-white rounded shadow-sm">
                        <h4>Total Amount</h4>
                        <hr />
                        <h3 class="text-success text-end">@TotalSum.ToString("N2") PLN</h3>
                        <button class="btn btn-success btn-lg w-100 mt-3 shadow" @onclick="Checkout">
                            Checkout
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<CartItems>? cartItems;
    private decimal TotalSum => cartItems?.Where(i => i.Product != null).Sum(i => i.Product.Price * i.Quantity) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        await RefreshCart();
    }

    private async Task RefreshCart()
    {
        try
        {
            if (SharedState.UserId > 0)
            {
  
                var data = await DB.CartItems
                    .Include(c => c.Product)
                    .Where(c => c.CustomerId == SharedState.UserId)
                    .ToListAsync();

                cartItems = data ?? new List<CartItems>();
            }
            else
            {
                cartItems = new List<CartItems>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"DB Error: {ex.Message}");
            cartItems = new List<CartItems>(); 
        }
    }

    private async Task UpdateQty(CartItems item, int change)
    {
        var dbItem = await DB.CartItems.FindAsync(item.CartItemId);
        if (dbItem != null)
        {
            dbItem.Quantity += change;
            if (dbItem.Quantity <= 0) DB.CartItems.Remove(dbItem);

            await DB.SaveChangesAsync();
            await RefreshCart();
        }
    }

    private async Task RemoveItem(CartItems item)
    {
        var dbItem = await DB.CartItems.FindAsync(item.CartItemId);
        if (dbItem != null)
        {
            DB.CartItems.Remove(dbItem);
            await DB.SaveChangesAsync();
            await RefreshCart();
        }
    }

    private void Checkout() => Navigation.NavigateTo("/checkout");
}