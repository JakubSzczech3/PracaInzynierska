@page "/cart"
@rendermode InteractiveServer
@using InterfejsPrototyp.Other
@using Microsoft.EntityFrameworkCore
@inject SharedStateService SharedState
@inject ProtectedSessionStorage SessionStorage
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject NavigationManager Navigation
@inject ProjectDbContext DB

<PageTitle>Your Cart</PageTitle>

<header class="header-section">
    <div class="header-left">
        <div class="header-logo" @onclick="GoToHome"></div>
        <h1>@(SharedState.UserId > 0 ? $"{SharedState.UserName}'s cart" : "Shopping cart")</h1>
    </div>
</header>

<main class="main-content-area">
    <div class="cart-container">
        @if (SharedState.UserId <= 0)
        {
            <div class="access-denied-container">
                <div class="access-card">
                    <h2>Access denied</h2>
                    <p>You must be logged in to view your cart.</p>
                    <div class="access-actions">
                        <button class="btn-login" @onclick="GoToLogin">Log in</button>
                        <button class="btn-home" @onclick="GoToHome">Back to home</button>
                    </div>
                </div>
            </div>
        }
        else
        {
            @if (cartItems == null)
            {
                <div class="loader-container">
                    <div class="spinner"></div>
                    <p>Connecting to database...</p>
                </div>
            }
            else if (cartItems.Count == 0)
            {
                <div class="empty-cart-card">
                    <h3 class="empty-title">Your cart is empty</h3>
                    <button class="btn-primary" @onclick="GoToProducts">Go to products</button>
                </div>
            }
            else
            {
                <div class="cart-grid">
                    <div class="items-list">
                        @foreach (var item in cartItems)
                        {
                            if (item.Product != null)
                            {
                                <div class="cart-item-card">
                                    <div class="item-details">
                                        <img src="@(string.IsNullOrEmpty(item.Product.ImageUrl) ? "/uploads/placeholder.jpg" : item.Product.ImageUrl)"
                                             class="cart-img-preview" />

                                        <div class="item-info">
                                            <h5 class="product-name">@item.Product.Name</h5>
                                            <span class="price-tag">@item.Product.Price.ToString("N2") PLN</span>
                                        </div>

                                        <div class="qty-control">
                                            <button class="qty-btn" @onclick="() => UpdateQty(item, -1)">-</button>
                                            <span class="qty-value">@item.Quantity</span>
                                            <button class="qty-btn" @onclick="() => UpdateQty(item, 1)">+</button>
                                        </div>

                                        <div class="item-total-section">
                                            <div class="item-total">@((item.Product.Price * item.Quantity).ToString("N2")) PLN</div>
                                            <button class="remove-btn" @onclick="() => RemoveItem(item)">Remove</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <div class="summary-section">
                        <div class="summary-card">
                            <div class="summary-header">
                                <h4>Order summary</h4>
                            </div>
                            <div class="summary-body">
                                <div class="summary-row">
                                    <span>Items count:</span>
                                    <b>@cartItems.Sum(i => i.Quantity)</b>
                                </div>
                                <div class="total-row">
                                    <span>Total:</span>
                                    <span class="total-price">@TotalSum.ToString("N2") PLN</span>
                                </div>

                                @if (!string.IsNullOrEmpty(errorMessage))
                                {
                                    <div class="error-msg">@errorMessage</div>
                                }

                                <button class="btn-primary" @onclick="Checkout">Proceed to checkout</button>
                                <button class="btn-secondary" @onclick="GoToProducts">Continue shopping</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</main>

<footer class="footer-section">
    Footer
</footer>
@code {
    private List<CartItems>? cartItems;
    private decimal TotalSum => cartItems?.Where(i => i.Product != null).Sum(i => i.Product.Price * i.Quantity) ?? 0;
    private void GoToHome() => Navigation.NavigateTo("/");
    private void GoToLogin() => Navigation.NavigateTo("/login");
    private void GoToProducts() => Navigation.NavigateTo("/products");

    protected override Task OnInitializedAsync()
    {
        return Task.CompletedTask;
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (SharedState.UserId <= 0)
            {
                var resultId = await SessionStorage.GetAsync<int>("userId");
                if (resultId.Success && resultId.Value > 0)
                {
                    var resultName = await SessionStorage.GetAsync<string>("userName");
                    SharedState.Login(resultId.Value, resultName.Value ?? "User");

                    await RefreshCart();
                    StateHasChanged();
                }
            }
            else
            {
                await RefreshCart();
                StateHasChanged();
            }
        }
    }
    private async Task RefreshCart()
    {
        try
        {
            if (SharedState.UserId > 0)
            {
  
                var data = await DB.CartItems
                    .Include(c => c.Product)
                    .Where(c => c.CustomerId == SharedState.UserId)
                    .ToListAsync();

                cartItems = data ?? new List<CartItems>();
            }
            else
            {
                cartItems = new List<CartItems>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"DB Error: {ex.Message}");
            cartItems = new List<CartItems>(); 
        }
    }
    private string errorMessage = "";
    private async Task UpdateQty(CartItems item, int change)
    {
        errorMessage = "";

        var dbItem = await DB.CartItems.FindAsync(item.CartItemId);
        if (dbItem != null)
        {
            var product = await DB.Products.FindAsync(item.ProductId);
            if (product != null)
            {
                await DB.Entry(product).ReloadAsync();

                int finalQty = dbItem.Quantity + change;

                if (finalQty < 1)
                {
                    finalQty = 1; 
                    errorMessage = "Quantity has to be at least one.";
                }

                if (finalQty > product.StockQuantity)
                {
                    finalQty = product.StockQuantity;
                    errorMessage = $"Only {product.StockQuantity} left.";
                }

                dbItem.Quantity = finalQty;
                await DB.SaveChangesAsync();

                await RefreshCart();
            }
        }
    }

    private async Task RemoveItem(CartItems item)
    {
        var dbItem = await DB.CartItems.FindAsync(item.CartItemId);
        if (dbItem != null)
        {
            DB.CartItems.Remove(dbItem);
            await DB.SaveChangesAsync();
            await RefreshCart();
        }
    }

    private async Task Checkout()
    {
        var itemsInCart = await DB.CartItems
            .Where(c => c.CustomerId == SharedState.UserId)
            .ToListAsync();

        if (!itemsInCart.Any()) return;
        var firstItem = itemsInCart.First();
        var newOrder = new Order
        {
            CustomerId = SharedState.UserId,
            OrderDate = DateTime.Now,
            TotalAmount = TotalSum, 
            Quantity = firstItem.Quantity,
            Status = "Pending",
            ProductId = itemsInCart.First().ProductId
        };

        DB.Orders.Add(newOrder);
        await DB.SaveChangesAsync(); 

        Navigation.NavigateTo($"/payment-gateway/{newOrder.OrderId}");
    }
}