@page "/products"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>Products</PageTitle>
<div class="background">
<header class="header-section">
    <div class="header-left">
            <div class="header-logo" @onclick="GoToHome">
        </div>
        <div class="search-bar">
            <input type="text" placeholder="Szukany produkt...">
            <button type="button" class="search-button" @onclick="GoToProducts">Szukaj</button>
        </div>
    </div>
    <div class="header-right">
            <button class="auth-button" @onclick="Settings">Ustawienia</button>
        <button class="auth-button">Wyloguj</button>
    </div>
</header>

    <main class ="main-content">

        <aside class="sidebar">
            <h5>Filtrowanie</h5>

            <div class="filter-option">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" value="" id="Filtr">
                    <label class="form-check-label" for="Filtr">
                        Filtr
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" value="" id="Filtr">
                    <label class="form-check-label" for="Filtr">
                        Filtr
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" value="" id="Filtr">
                    <label class="form-check-label" for="Filtr">
                        Filtr
                    </label>
                </div>
            </div>

            <div class="filter-option">
                <label for="priceRange" class="form-label">Przedzial cenowy:</label>
                <input type="range" class="form-range" min="0" max="100" step="1" id="priceRange" value="50">
            </div>

            <h6>Filtr2</h6>
            <div class="filter-option">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" value="" id="option1">
                    <label class="form-check-label" for="option1">
                        Filtr
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" value="" id="option2">
                    <label class="form-check-label" for="option2">
                        Filtr
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" value="" id="option3">
                    <label class="form-check-label" for="option3">
                        Filtr
                    </label>
                </div>
            </div>
        </aside>

        <div class="product-list-panel">
            <div class="sort-bar">
                <label for="sortby">Sortuj po:</label>
                <select class="form-select" id="sortby">
                    <option value="1">Opcja 1</option>
                    <option value="2">Opcja 2</option>
                    <option value="3">Opcja 3</option>
                </select>
            </div>


            <div class="row">
                <div class="col">
                    
                        <div class="img-holder">
                            <i class=""></i>
                        </div>
                        <div>
                            <h5>TYTUŁ</h5>
                            <p>KRÓTKI OPIS I CENA</p>
                        </div>
                    
                </div>
                <div class="col">
                        <div class="img-holder">
                            <i class=""></i>
                        </div>
                        <div>
                            <h5>TYTUŁ</h5>
                            <p>KRÓTKI OPIS I CENA</p>
                        </div>
                    
                </div>
                <div class="col">
                    
                        <div class="img-holder">
                            <i class=""></i>
                        </div>
                        <div>
                            <h5>TYTUŁ</h5>
                            <p>KRÓTKI OPIS I CENA</p>
                        </div>
                    
                </div>
            </div>


            <nav aria-label="Page navigation" class="d-flex justify-content-center mt-5">
                <ul class="pagination">
                    <li class="page-item active"><a class="page-link" >1</a></li>
                    <li class="page-item"><a class="page-link" >2</a></li>
                    <li class="page-item"><a class="page-link" >3</a></li>
                    <li class="page-item"><a class="page-link" >...</a></li>
                    <li class="page-item"><a class="page-link" >10</a></li>
                    <li class="page-item"><a class="page-link" >11</a></li>
                </ul>
            </nav>
        </div>
    </main>



<footer class="footer-section">
    Footer
</footer>
</div>
@code {
    private void GoToProducts()
    {

        Navigation.NavigateTo("/products");
    }
    private void Settings()
    {

        Navigation.NavigateTo("/settings");
    }
    private void GoToHome()
    {
        Navigation.NavigateTo("/"); 
    }
}