@page "/payment-gateway/{OrderId:int}"
@rendermode InteractiveServer
@inject ProjectDbContext DB
@inject NavigationManager Navigation
@inject SharedStateService SharedState
@inject ProtectedSessionStorage SessionStorage
@inject InterfejsPrototyp.Other.IPaymentService PaymentService
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@using Microsoft.EntityFrameworkCore

<header class="header-section">
    <div class="header-left">
        <div class="header-logo" @onclick="GoToHome"></div>
    </div>
</header>

<main class="main-content">
    <div class="payment-container">
        <div class="content-block payment-card">
            @if (!isSuccess)
            {
                <h3><i class="bi bi-shield-lock-fill"></i> Secure payment gateway</h3>
                <hr />

                @if (OrderAmount == 0 && string.IsNullOrEmpty(errorMessage))
                {
                    <div class="text-center p-3">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                }
                else
                {
                    <div class="payment-details">
                        <p>Order ID: <b>#@OrderId</b></p>
                        <p>Amount to pay: <span class="price-tag">@OrderAmount.ToString("N2") PLN</span></p>
                    </div>

                    <div class="action-buttons">
                        <div class="action-buttons">
                            @if (isProcessing)
                            {
                                <div class="processing-status text-center">
                                    <div class="spinner-border text-primary" role="status"></div>
                                    <p>Connecting to secure provider...</p>
                                </div>
                            }
                            else
                            {
                                <button class="btn-provider" @onclick="HandlePayment">
                                    <i class="bi bi-credit-card"></i> Pay with card
                                </button>
                                <button class="btn-cancel" @onclick="Cancel">Cancel and return</button>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center p-4">
                    <i class="bi bi-check-circle-fill"></i>
                    <h2 class="mt-3">Thank you!</h2>
                    <p>Your payment for order <b>#@OrderId</b> has been approved.</p>
                    <hr />
                    <button class="btn-execute" @onclick="GoToHome">Return to Shop</button>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3">
                    @errorMessage
                </div>
            }
        </div>
    </div>
</main>

<footer class="footer-section">
    Footer
</footer>

@code {
    [Parameter] public int OrderId { get; set; }
    private decimal OrderAmount;
    private bool isProcessing = false;
    private string errorMessage = "";
    private void GoToHome() => Navigation.NavigateTo("/", forceLoad: true);
    private bool isSuccess = false;

    protected override Task OnInitializedAsync()
    {
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (SharedState.UserId == 0)
            {
                var resultId = await SessionStorage.GetAsync<int>("userId");
                if (resultId.Success && resultId.Value > 0)
                {
                    var resultName = await SessionStorage.GetAsync<string>("userName");
                    SharedState.Login(resultId.Value, resultName.Value ?? "User");
                }
            }


            var order = await DB.Orders.FindAsync(OrderId);
            if (order == null || order.CustomerId != SharedState.UserId || order.Status == "Paid")
            {
                Navigation.NavigateTo("/cart");
                return;
            }

            OrderAmount = order.TotalAmount;
            StateHasChanged();
        }
    }
    private async Task HandlePayment()
    {
        isProcessing = true;
        errorMessage = "";
        StateHasChanged();

        try
        {
            await Task.Delay(2000);

            var paymentSuccess = await PaymentService.ProcessPaymentAsync(OrderId, OrderAmount);

            if (paymentSuccess)
            {
                await FinalizeTransaction();
            }
            else
            {
                errorMessage = "Payment rejected by the provider.";
                isProcessing = false;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Transaction failed: {ex.Message}";
            isProcessing = false;
        }
    }

    private async Task FinalizeTransaction()
    {
        using var transaction = await DB.Database.BeginTransactionAsync();
        try
        {
            var order = await DB.Orders.FindAsync(OrderId);
            if (order == null) return;

            var itemsInCart = await DB.CartItems
                .Where(c => c.CustomerId == SharedState.UserId)
                .ToListAsync();

            if (itemsInCart.Any())
            {
                int totalQty = itemsInCart.Sum(i => i.Quantity);
                order.ProductId = itemsInCart.First().ProductId;
                order.Quantity = totalQty;
            }
            else
            {
                throw new Exception("Cart is empty!");
            }

            foreach (var item in itemsInCart)
            {
                var product = await DB.Products.FindAsync(item.ProductId);
                if (product != null)
                {
                    await DB.Entry(product).ReloadAsync();

                    if (product.StockQuantity >= item.Quantity)
                    {
                        product.StockQuantity -= item.Quantity;

                        if (product.StockQuantity <= 0)
                        {
                            product.StockQuantity = 0;
                            product.IsActive = false;
                        }
                    }
                    else
                    {
                        throw new Exception($"Product {product.Name} sold out in the meantime!");
                    }
                }
            }

            order.Status = "Paid";
            await DB.SaveChangesAsync();
            DB.CartItems.RemoveRange(itemsInCart);

            await DB.SaveChangesAsync();
            await transaction.CommitAsync();

            isSuccess = true;
            StateHasChanged();

            await Task.Delay(6000);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            await transaction.RollbackAsync();
            errorMessage = $"Transaction Failed: {ex.Message}";
            isProcessing = false;
            StateHasChanged();
        }
    }

    private void Cancel() => Navigation.NavigateTo("/cart");
}